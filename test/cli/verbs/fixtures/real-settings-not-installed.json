{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/some-other-tool --init",
            "timeout": 5,
            "id": "other-tool"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/linters/lint-check.sh",
            "timeout": 15,
            "id": "lint-check"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["Bash(npm test)"]
  }
}
